# PostgreSQL
POSTGRES_DB=textbook_video
POSTGRES_USER=textbook_video
POSTGRES_PASSWORD=textbook_video
DATABASE_URL=postgresql+asyncpg://textbook_video:textbook_video@localhost:5432/textbook_video

# Backend
APP_NAME=Textbook-to-Video Learning Platform
APP_ENVIRONMENT=development
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:5057
STATIC_ASSETS_PATH=rendered

# Ollama (LLM Provider Layer)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
# Optional: a second pulled model used as a fallback if the primary model
# call fails (timeout, connection error, schema-validation failure). Leave
# unset to run with a single provider only.
OLLAMA_FALLBACK_MODEL=
OLLAMA_TIMEOUT_SECONDS=120
# Context window (tokens) requested from Ollama. Left unset, Ollama falls
# back to a small default and silently truncates long parsed chapters.
OLLAMA_NUM_CTX=8192

# Maximum number of video-render pipelines allowed to run concurrently;
# requests beyond this stay QUEUED until a slot frees up.
MAX_CONCURRENT_RENDER_JOBS=2

# Assembly stage — where each beat's video clip comes from:
#   local   (default) offline, no-cost local icon animation; no external dependency.
#   veo     real generated footage per beat via Veo3; requires GOOGLE_API_KEY.
#   kaggle  clips generated by the Wan2.1 Kaggle notebook, read from KAGGLE_CLIPS_DIR
#           (named <clip_cache_key>.mp4, matching the beats.json export).
VIDEO_CLIP_PROVIDER=local

# Veo (only used when VIDEO_CLIP_PROVIDER=veo)
GOOGLE_API_KEY=
VEO_MODEL=veo-3.1-fast-generate-preview

# Kaggle (only used when VIDEO_CLIP_PROVIDER=kaggle)
KAGGLE_CLIPS_DIR=

# Flutter (--dart-define values)
# API_BASE_URL=http://localhost:8000
