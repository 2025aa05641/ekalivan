# PostgreSQL
POSTGRES_DB=textbook_video
POSTGRES_USER=textbook_video
POSTGRES_PASSWORD=textbook_video
DATABASE_URL=postgresql+asyncpg://textbook_video:textbook_video@localhost:5432/textbook_video

# Backend
APP_NAME=Textbook-to-Video Learning Platform
APP_ENVIRONMENT=development
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:5057
STATIC_ASSETS_PATH=rendered

# Ollama (LLM Provider Layer)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
OLLAMA_TIMEOUT_SECONDS=120

# Flutter (--dart-define values)
# API_BASE_URL=http://localhost:8000
